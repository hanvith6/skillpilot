# SkillPilot - Backend Environment Variables
# Copy this file to .env and fill in the values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# LLM Providers
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key  # Optional fallback

# Primary LLM provider: "gemini" or "openai"
PRIMARY_LLM=gemini

# Razorpay (India payments)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Stripe (Global payments)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# CORS - comma-separated origins (REQUIRED for production)
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_GENERATION_REQUESTS=10
RATE_LIMIT_GENERATION_WINDOW=60

# Frontend URL - (REQUIRED for production, used for payment redirects)
FRONTEND_URL=http://localhost:3000
