{
  "project_name": "SKILLMATE AI",
  "design_philosophy": {
    "core_identity": "The Engineering Companion",
    "emotional_tone": "Confident, Tech-Forward, Late-Night-Hacker, Reliable",
    "visual_style": "Dark Glassmorphism",
    "theme_mode": "dark",
    "principles": [
      "Fusion over Imitation: Mix academic rigor with cyberpunk aesthetics",
      "Content is King: Data and tools first, decoration second",
      "Glassmorphism: Use high-end 'Crystal' glass, not muddy blur"
    ]
  },
  "typography": {
    "font_family": {
      "headings": "Outfit, sans-serif",
      "body": "Inter, sans-serif",
      "code": "JetBrains Mono, monospace"
    },
    "scale": {
      "h1": "text-5xl md:text-6xl font-bold tracking-tight",
      "h2": "text-4xl font-semibold tracking-tight",
      "h3": "text-2xl font-medium",
      "body_lg": "text-lg leading-relaxed",
      "body": "text-base leading-relaxed text-muted-foreground",
      "caption": "text-sm text-muted-foreground uppercase tracking-wider"
    },
    "installation": "Imports are handled via Google Fonts in index.css"
  },
  "colors": {
    "palette": {
      "background": "#020617",
      "foreground": "#F8FAFC",
      "primary": {
        "DEFAULT": "#7C3AED",
        "foreground": "#FFFFFF",
        "gradient_start": "#7C3AED",
        "gradient_end": "#4F46E5"
      },
      "secondary": {
        "DEFAULT": "#1E293B",
        "foreground": "#F8FAFC"
      },
      "accent": {
        "DEFAULT": "#10B981",
        "foreground": "#020617"
      },
      "muted": {
        "DEFAULT": "#0F172A",
        "foreground": "#94A3B8"
      },
      "border": "#1E293B",
      "glass": {
        "bg": "rgba(255, 255, 255, 0.03)",
        "border": "rgba(255, 255, 255, 0.08)",
        "blur": "backdrop-blur-xl"
      }
    },
    "gradients": {
      "hero": "bg-gradient-to-r from-violet-600/20 via-indigo-600/20 to-slate-900/50",
      "card_hover": "hover:bg-gradient-to-br hover:from-white/5 hover:to-transparent",
      "text_gradient": "bg-clip-text text-transparent bg-gradient-to-r from-violet-400 to-indigo-400"
    }
  },
  "components": {
    "button": {
      "default": "h-11 px-8 rounded-lg font-medium transition-all duration-300",
      "primary": "bg-violet-600 hover:bg-violet-700 text-white shadow-[0_0_20px_rgba(124,58,237,0.3)] hover:shadow-[0_0_30px_rgba(124,58,237,0.5)]",
      "ghost": "hover:bg-white/5 text-slate-300 hover:text-white"
    },
    "card": {
      "base": "bg-slate-950/40 backdrop-blur-md border border-white/5 rounded-xl p-6 transition-all duration-300",
      "hover": "hover:border-violet-500/30 hover:bg-slate-900/60 hover:shadow-2xl hover:shadow-violet-900/10 hover:-translate-y-1"
    },
    "input": {
      "base": "bg-slate-950/50 border-white/10 focus:border-violet-500 focus:ring-violet-500/20 rounded-lg h-11"
    },
    "badge": {
      "base": "rounded-full px-3 py-1 text-xs font-medium border",
      "variant_success": "bg-emerald-500/10 text-emerald-400 border-emerald-500/20",
      "variant_warning": "bg-amber-500/10 text-amber-400 border-amber-500/20"
    }
  },
  "layout": {
    "container": "container mx-auto px-4 md:px-6 max-w-7xl",
    "section_spacing": "py-24 md:py-32",
    "bento_grid": "grid grid-cols-1 md:grid-cols-3 gap-6",
    "dashboard_grid": "grid grid-cols-1 lg:grid-cols-4 gap-6"
  },
  "motion": {
    "transitions": "transition-all duration-300 ease-out",
    "animation_classes": {
      "fade_in": "animate-in fade-in zoom-in-95 duration-500",
      "slide_up": "animate-in slide-in-from-bottom-4 duration-500"
    }
  },
  "image_urls": {
    "hero_bg": "https://images.unsplash.com/photo-1702726001096-096efcf640b8?crop=entropy&cs=srgb&fm=jpg&q=85",
    "feature_resume": "https://images.unsplash.com/photo-1606327054581-0a1d4bf42831?crop=entropy&cs=srgb&fm=jpg&q=85",
    "feature_project": "https://images.unsplash.com/photo-1721244654346-9be0c0129e36?crop=entropy&cs=srgb&fm=jpg&q=85",
    "feature_interview": "https://images.unsplash.com/photo-1758520144427-ddb02ac74e9d?crop=entropy&cs=srgb&fm=jpg&q=85",
    "testimonial_user": "https://images.unsplash.com/photo-1628257489884-bdf3bbbf7785?crop=entropy&cs=srgb&fm=jpg&q=85",
    "logo_placeholder": "https://placehold.co/40x40/7C3AED/FFFFFF?text=S"
  },
  "universal_guidelines": [
    "Always use 'Outfit' font for headings to give a tech feel.",
    "Dark colors look good when used independently without gradients. DO NOT use dark colors as gradients.",
    "Use glass-morphism effects with backdrop filters (12-24px blur).",
    "Every interaction needs micro-animations - hover states, transitions.",
    "Use 2-3x more spacing than feels comfortable.",
    "All interactive elements MUST include data-testid attributes."
  ],
  "instructions_to_main_agent": [
    "Implement the 'Outfit' font via Google Fonts import in index.css.",
    "Use the specific violet gradients defined in colors.primary.",
    "Ensure the Dashboard uses the 'dashboard_grid' layout for density.",
    "For the Resume Builder, use a split-screen layout (Input Left, Preview Right).",
    "For 'Emergent Mode', use a glowing amber/red border effect to signify urgency/speed."
  ]
}